+
+void CDWUSBGadgetEndpoint::SetHalt (boolean bIn, boolean bHalt)
+{
+	if (bHalt)
+	{
+		Stall (bIn);
+
+		return;
+	}
+
+	LOGWARN ("EP%u: Clear STALL condition", m_nEP);
+
+	CDWHCIRegister EPCtrl (bIn ? DWHCI_DEV_IN_EP_CTRL (m_nEP)
+				   : DWHCI_DEV_OUT_EP_CTRL (m_nEP));
+	EPCtrl.Read ();
+	EPCtrl.And (~DWHCI_DEV_EP_CTRL_STALL);
+
+	// Reset the data toggle to DATA0 (USB 2.0 spec 9.4.5) for bulk and
+	// interrupt EPs, so the next transaction after the halt is in sync.
+	if (m_nEP != 0)
+	{
+		EPCtrl.Or (DWHCI_DEV_EP_CTRL_SETDPID_D0);
+	}
+
 	EPCtrl.Write ();
+
+	// If a transfer was armed while the EP was halted (e.g. a CSW queued
+	// behind a Bulk-In STALL by a mass storage gadget), restart it now.
+	if (m_nEP != 0 && IsTransferActive ())
+	{
+		EPCtrl.Read ();
+		EPCtrl.Or (DWHCI_DEV_EP_CTRL_EP_ENABLE);
+		EPCtrl.Or (DWHCI_DEV_EP_CTRL_CLEAR_NAK);
+		EPCtrl.Write ();
+	}
 }
 
+boolean CDWUSBGadgetEndpoint::IsHalted (boolean bIn) const
+{
+	CDWHCIRegister EPCtrl (bIn ? DWHCI_DEV_IN_EP_CTRL (m_nEP)
+				   : DWHCI_DEV_OUT_EP_CTRL (m_nEP));
+
+	return !!(EPCtrl.Read () & DWHCI_DEV_EP_CTRL_STALL);
+}
