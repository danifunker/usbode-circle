+boolean CDWUSBGadget::SetEndpointHalt (u8 uchEPAddress, boolean bHalt)
+{
+	unsigned nEP = uchEPAddress & 0x0F;
+	boolean bIn = !!(uchEPAddress & 0x80);
+
+	if (   nEP == 0
+	    || nEP > NumberOfEPs
+	    || !m_pEP[nEP])
+	{
+		return FALSE;
+	}
+
+	m_pEP[nEP]->SetHalt (bIn, bHalt);
+
+	return TRUE;
+}
+
+boolean CDWUSBGadget::IsEndpointHalted (u8 uchEPAddress)
+{
+	unsigned nEP = uchEPAddress & 0x0F;
+	boolean bIn = !!(uchEPAddress & 0x80);
+
+	if (   nEP > NumberOfEPs
+	    || !m_pEP[nEP])
+	{
+		return FALSE;
+	}
+
+	return m_pEP[nEP]->IsHalted (bIn);
+}
